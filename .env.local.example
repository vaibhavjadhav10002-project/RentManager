# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Push Notifications (PWA) ────────────────────────────────────────────────
# Service role key: Supabase Dashboard → Project Settings → API → service_role
# (server-only — never expose this with NEXT_PUBLIC_, it bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Ready to use as-is, or generate your own with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BAG3ThOpRLoRZ7tkNOAFd-Veef47TzGb1aheTYkXDzs8WjD8D01sdRv0aMlyl-phzUDuwDu6cRYzOvUML4lKu8k
VAPID_PRIVATE_KEY=9OSovZEJlrlsBF0qyPxtTNUaQN7OevrtRMKdYB8Lthg
VAPID_SUBJECT=mailto:owner@example.com

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Super Admin (set this ONCE after first deploy) ─────────────────────────
# This email will be auto-promoted to super_admin role on first login
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your-admin-email@gmail.com
